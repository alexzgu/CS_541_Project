Bootstrap: docker
From: python:3.12-slim

%files
    ./test_script.py /app/test_script.py

%post
    pip install --upgrade pip
    pip install numpy

%runscript
    NOW=$(date)
    echo "Container was created $NOW"
    echo "Arguments received: $*"

    cd /app
    python test_script.py "$@"

%labels
    Author Alex Gu
    Version v1.0

%help
    Hello :D